  "services": {
    "intent": {
      "name": "Send mower action",
      "description": "Sends an action command to a STIHL iMow mower.",
      "fields": {
        "mower_device": {
          "name": "Mower",
          "description": "The mower to send the action to."
        },
        "action": {
          "name": "Action",
          "description": "The action the mower should perform."
        },
        "duration": {
          "name": "Mowing duration",
          "description": "Mowing duration in minutes. Only used when the action is 'Start mowing from point'."
        },
        "startpoint": {
          "name": "Starting point",
          "description": "Mower-defined starting point. Only used when the action is 'Start mowing from point' and the mower should not start from the dock."
        },
        "starttime": {
          "name": "Start time",
          "description": "Time when the mower should start mowing. Only used when the action is 'Start mowing'."
        },
        "endtime": {
          "name": "End time",
          "description": "Time when the mower should stop mowing. Only used when the action is 'Start mowing'."
        }
      }
    }
